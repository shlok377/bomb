    {
      "id": "frequential-deciphering",
      "title": "On the Subject of Morse Code",
      "flavorText": "An antiquated form of naval communication... pay attention and you might just learn something.",
      "content": [
        {
          "type": "text",
          "text": "Note: The signal pattern will always begin immediately following a brief GREEN sync pulse from the LED. Dots will appear as circles, while Bars (Dashes) will appear as horizontal rectangles."
        },
        {
          "type": "text",
          "text": "Identify word:"
        },
        {
          "type": "text",
          "text": "Start: After Green pulse."
        },
        {
          "type": "text",
          "text": "Dot: Short flash."
        },
        {
          "type": "text",
          "text": "Dash: Long flash."
        },
        {
          "type": "text",
          "text": "Match word to frequency, tune, and press TX."
        }
      ],
      "logic": {
        "words": [
          {"word": "shell", "freq": "3.505"}, {"word": "halls", "freq": "3.515"},
          {"word": "slick", "freq": "3.522"}, {"word": "trick", "freq": "3.532"},
          {"word": "boxes", "freq": "3.535"}, {"word": "leaks", "freq": "3.542"},
          {"word": "strobe", "freq": "3.545"}, {"word": "bistro", "freq": "3.552"},
          {"word": "flick", "freq": "3.555"}, {"word": "bombs", "freq": "3.565"},
          {"word": "break", "freq": "3.572"}, {"word": "brick", "freq": "3.575"},
          {"word": "steak", "freq": "3.582"}, {"word": "sting", "freq": "3.592"},
          {"word": "vector", "freq": "3.595"}, {"word": "beats", "freq": "3.600"}
        ]
      }
    },
    {
      "id": "navigational-algorithms",
      "title": "On the Subject of Mazes",
      "flavorText": "This seems to be some kind of maze, probably stolen off of a restaurant placemat.",
      "content": [
        {
          "type": "text",
          "text": "Find the maze by matching the Green circles to a grid below."
        },
        {
          "type": "text",
          "text": "Ask the defuser for the starting and ending positions."
        },
        {
          "type": "text",
          "text": "White Box: Your Position."
        },
        {
          "type": "text",
          "text": "Red Triangle: Goal."
        },
        {
          "type": "text",
          "text": "<strong>Move without hitting walls.</strong>"
        }
      ],
      "logic": {
        "use_visual_grid": true
      }
    },
    {
      "id": "cryptographic-passphrases",
      "title": "On the Subject of Passwords",
      "flavorText": "Fortunately this password doesn't seem to meet standard government security requirements...",
      "content": [
        {
          "type": "text",
          "text": "1. Defuser: Scroll through all 6 letters in the first column and read them out loud to the Expert."
        },
        {
          "type": "text",
          "text": "2. Expert: Look at the word list in the manual. Cross off every word that does not start with one of those 6 letters."
        },
        {
          "type": "text",
          "text": "3. Defuser: Now scroll through the 6 letters in the second column."
        },
        {
          "type": "text",
          "text": "4. Expert: Look at your remaining words. Cross off any that don't have one of those letters in the second position."
        },
        {
          "type": "text",
          "text": "5. Repeat: Usually, by the 3rd or 4th column, there will only be one word left in the Expert's list."
        },
        {
          "type": "text",
          "text": "6. Action: The Expert tells the Defuser that word. The Defuser flips the letters to match it and hits Submit."
        }
      ],
      "logic": {
        "words": [
          "about", "after", "again", "below", "could", "every", "first", "found", "great", "house",
          "large", "learn", "never", "other", "place", "plant", "point", "right", "small", "sound",
          "spell", "still", "study", "their", "there", "these", "thing", "think", "three", "water",
          "where", "which", "world", "would", "write"
        ]
      }
    }
