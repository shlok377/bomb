    {
      "id": "verbal-relays",
      "title": "On the Subject of Who's on First",
      "flavorText": "This contraption is like something out of a sketch comedy routine... I'll keep this brief, as words only complicate matters.",
      "content": [
        {
          "type": "text",
          "text": "1. Identify the button position from Step 1 using the word on the Display."
        },
        {
          "type": "text",
          "text": "2. Identify the word list from Step 2 using the label on the button in that specific position."
        },
        {
          "type": "text",
          "text": "3. The Expert reads the words in the list one by one. The first word they say that is also present on one of the 6 buttons is the correct one to press."
        }
      ],
      "logic": {
        "step1": {
          "YES": "Middle Left", "FIRST": "Top Right", "DISPLAY": "Bottom Right", "OKAY": "Top Right", "SAYS": "Bottom Right", 
          "NOTHING": "Middle Left", "": "Bottom Left", "BLANK": "Middle Right", "NO": "Bottom Right", "LED": "Middle Left",
          "LEAD": "Bottom Right", "READ": "Middle Right", "RED": "Middle Right", "REED": "Bottom Left", "LEED": "Bottom Left",
          "HOLD ON": "Bottom Right", "YOU": "Middle Right", "YOU ARE": "Bottom Right", "YOUR": "Middle Right", "YOU'RE": "Middle Right",
          "UR": "Top Left", "THERE": "Bottom Right", "THEY'RE": "Bottom Left", "THEIR": "Middle Right", "THEY ARE": "Bottom Left",
          "SEE": "Bottom Right", "C": "Top Right", "CEE": "Bottom Right"
